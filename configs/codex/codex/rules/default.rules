prefix_rule(pattern=["/bin/bash", "-lc", "env GOOGLE_APPLICATION_CREDENTIALS=/home/wecker/.local/share/csvdb/obsidian_adc.json UV_CACHE_DIR=/tmp/uv-cache uv run python -c \"from google.cloud import bigquery; client = bigquery.Client(project='ionq-qec', location='US'); sql = '''WITH tagged AS ( SELECT CASE WHEN STARTS_WITH(LOWER(source_file_name), 'bb5_') THEN 'BB5' WHEN STARTS_WITH(LOWER(source_file_name), 'bb6_') THEN 'BB6' END AS batch, source_file_name, row_id FROM `ionq-qec.csvdb_core.codes_base` WHERE STARTS_WITH(LOWER(source_file_name), 'bb5_') OR STARTS_WITH(LOWER(source_file_name), 'bb6_') ) SELECT batch, COUNT(*) AS uploaded_rows, COUNT(DISTINCT source_file_name) AS files, COUNTIF(a.orthogonal) AS orth_true_rows, COUNTIF(IFNULL(a.odd_weight, FALSE)) AS odd_true_rows, COUNT(ds.row_id) AS frontier_summary_rows, COUNTIF(ds.is_confirmed) AS frontier_confirmed_rows FROM tagged t LEFT JOIN `ionq-qec.csvdb_core.code_analysis` a USING (row_id) LEFT JOIN `ionq-qec.csvdb_core.code_distance_summary` ds USING (row_id) GROUP BY batch ORDER BY batch''' ; rows = list(client.query(sql).result()); [print(dict(r.items())) for r in rows]\""], decision="allow")
