{
  "modelProviders": {
    "openai": [
      {
        "id": "qwen3-coder-next",
        "name": "weckerAA Qwen Coder Next",
        "baseUrl": "http://127.0.0.1:18023/v1",
        "description": "Qwen Coder served from weckerAA through the qwen SSH tunnel.",
        "envKey": "OPENAI_API_KEY",
        "generationConfig": {
          "contextWindowSize": 131072,
          "samplingParams": {
            "max_tokens": 2048,
            "temperature": 0.2,
            "top_p": 0.8
          }
        }
      }
    ]
  },
  "env": {
    "OPENAI_API_KEY": "local-vllm"
  },
  "generationConfig": {
    "contextWindowSize": 131072,
    "samplingParams": {
      "max_tokens": 2048,
      "temperature": 0.2,
      "top_p": 0.8
    }
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "qwen3-coder-next",
    "baseUrl": "http://127.0.0.1:18023/v1",
    "sessionTokenLimit": 122880,
    "skipStartupContext": true
  },
  "context": {
    "autoCompactThreshold": 0.85
  },
  "memory": {
    "enableAutoSkill": false
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "tools": {
    "disabled": [
      "write_file"
    ]
  },
  "$version": 4
}
