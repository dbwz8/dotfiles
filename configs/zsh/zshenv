# Keep early zsh startup quiet and safe. This runs before /etc/zsh/zshrc.

# Work around broken vendor completion symlinks (seen with Docker Desktop on WSL)
# before the system zshrc runs compinit.
vendor_completions_dir=/usr/share/zsh/vendor-completions
if [[ -d "$vendor_completions_dir" ]]; then
    for completion_file in "$vendor_completions_dir"/_*(N); do
        if [[ -L "$completion_file" && ! -r "$completion_file" ]]; then
            fpath=(${fpath:#$vendor_completions_dir})
            # Drop stale completion dumps created before vendor-completions was filtered.
            for dump_file in "${ZDOTDIR:-$HOME}"/.zcompdump*(N); do
                if command grep -aq '_python-argcomplete' "$dump_file" 2>/dev/null; then
                    command rm -f "$dump_file" "$dump_file".zwc
                fi
            done
            break
        fi
    done
fi
unset completion_file dump_file vendor_completions_dir

[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then . "$HOME/.nix-profile/etc/profile.d/nix.sh"; fi # added by Nix installer
