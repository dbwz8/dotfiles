#!/usr/bin/env bash
set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${BASEDIR}"

if command -v python3 >/dev/null 2>&1; then
    DOTBOT_DIR="submodules/dotbot"
    DOTBOT_BIN="bin/dotbot"
    python3 "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "install.conf.yaml" "${@}"
else
    $HOME/git/dotfiles/scripts/run.sh uvx dotbot -d $HOME/git/dotfiles -c install.conf.yaml
fi

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/git/dotfiles}"

mkdir -p "$HOME/.config/tmuxp"

ln -sf "$DOTFILES/tmux/tmux.conf" "$HOME/.tmux.conf"

# symlink each YAML session file
for f in "$DOTFILES"/tmux/sessions/*.yaml; do
  ln -sf "$f" "$HOME/.config/tmuxp/$(basename "$f")"
done
