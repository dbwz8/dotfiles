#!/usr/bin/env bash
set -euo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${BASEDIR}"
DOTFILES="${DOTFILES:-$BASEDIR}"

ensure_required_submodules() {
    local missing=()

    if [ ! -f "${BASEDIR}/submodules/dotbot/bin/dotbot" ]; then
        missing+=("submodules/dotbot")
    fi

    if [ ! -f "${BASEDIR}/submodules/kickstart.nvim/init.lua" ]; then
        missing+=("submodules/kickstart.nvim")
    fi

    if [ "${#missing[@]}" -eq 0 ]; then
        return 0
    fi

    if ! command -v git >/dev/null 2>&1; then
        printf '%s\n' "⚠️  git is unavailable; cannot initialize required submodules: ${missing[*]}" >&2
        return 1
    fi

    printf '%s\n' "📦 Initializing required submodules: ${missing[*]}"
    git submodule sync -- "${missing[@]}"
    git submodule update --init --recursive -- "${missing[@]}"
}

should_install_linux_packages() {
    case "${DOTFILES_INSTALL_SYSTEM_PACKAGES:-auto}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        0|false|FALSE|no|NO)
            return 1
            ;;
    esac

    if [ "$(uname -s)" != "Linux" ]; then
        return 1
    fi

    if ! command -v sudo >/dev/null 2>&1 || ! sudo -n true >/dev/null 2>&1; then
        printf '%s\n' "⚠️  sudo is unavailable or requires interaction; skipping privileged Linux package installation." >&2
        printf '%s\n' "    Set DOTFILES_INSTALL_SYSTEM_PACKAGES=1 to force these apt-based install steps." >&2
        return 1
    fi

    if [ -n "${SLURM_CONF:-}" ] || [ -f /etc/slurm/slurm.conf ] || [ -d /etc/slurm/slurm.conf.d ] \
        || command -v slurmctld >/dev/null 2>&1 || command -v slurmdbd >/dev/null 2>&1; then
        printf '%s\n' "⚠️  Detected a Slurm-managed host; skipping privileged Linux package installation." >&2
        printf '%s\n' "    Set DOTFILES_INSTALL_SYSTEM_PACKAGES=1 to force these apt-based install steps." >&2
        return 1
    fi

    return 0
}

should_install_macos_packages() {
    case "${DOTFILES_INSTALL_SYSTEM_PACKAGES:-auto}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        0|false|FALSE|no|NO)
            return 1
            ;;
    esac

    [ "$(uname -s)" = "Darwin" ]
}

uv_bin() {
    if command -v uv >/dev/null 2>&1; then
        command -v uv
        return 0
    fi

    local os arch candidate
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    if [ "$os" = "darwin" ]; then
        os="macos"
    fi

    arch=$(uname -m)
    if [ "$arch" = "x86_64" ]; then
        arch="amd64"
    elif [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
        arch="arm64"
    fi

    candidate="$HOME/.dotbins/$os/$arch/bin/uv"
    if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    return 1
}

DOTFILES_BACKUP_ROOT=""

dotfiles_backup_root() {
    if [ -n "${DOTFILES_BACKUP_DIR:-}" ]; then
        printf '%s\n' "$DOTFILES_BACKUP_DIR"
        return 0
    fi

    if [ -z "$DOTFILES_BACKUP_ROOT" ]; then
        DOTFILES_BACKUP_ROOT="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"
    fi

    printf '%s\n' "$DOTFILES_BACKUP_ROOT"
}

backup_link_conflict() {
    local target backup_root rel dest suffix
    target="$1"

    if [ -L "$target" ] || [ ! -e "$target" ]; then
        return 0
    fi

    backup_root="$(dotfiles_backup_root)"
    rel="${target#"$HOME"/}"
    if [ "$rel" = "$target" ]; then
        rel="${target#/}"
    fi
    dest="$backup_root/$rel"
    mkdir -p "$(dirname "$dest")"

    suffix=1
    while [ -e "$dest" ] || [ -L "$dest" ]; do
        dest="$backup_root/$rel.$suffix"
        suffix=$((suffix + 1))
    done

    printf '%s\n' "Backing up existing $target -> $dest"
    mv "$target" "$dest"
}

remove_legacy_managed_link() {
    local target
    target="$1"

    if [ -L "$target" ]; then
        printf '%s\n' "Removing legacy managed link $target"
        rm -f "$target"
    fi
}

migrate_legacy_codex_home_symlink() {
    local codex_home codex_source resolved_home resolved_source backup_root backup_dir suffix
    codex_home="$HOME/.codex"
    codex_source="$BASEDIR/configs/codex/codex"

    if [ ! -L "$codex_home" ] || [ ! -d "$codex_home" ] || [ ! -d "$codex_source" ]; then
        return 0
    fi

    resolved_home="$(cd "$codex_home" && pwd -P)"
    resolved_source="$(cd "$codex_source" && pwd -P)"

    if [ "$resolved_home" != "$resolved_source" ]; then
        return 0
    fi

    backup_root="$(dotfiles_backup_root)"
    backup_dir="$backup_root/codex-home-state"
    suffix=1
    while [ -e "$backup_dir" ] || [ -L "$backup_dir" ]; do
        backup_dir="$backup_root/codex-home-state.$suffix"
        suffix=$((suffix + 1))
    done

    mkdir -p "$backup_dir"
    printf '%s\n' "Migrating legacy $codex_home symlink to a real directory."
    printf '%s\n' "Backing up current Codex home state -> $backup_dir"
    cp -pR "$codex_home"/. "$backup_dir"/
    rm "$codex_home"
    mkdir -p "$codex_home"
    cp -pR "$backup_dir"/. "$codex_home"/
}

prepare_dotbot_link_conflicts() {
    migrate_legacy_codex_home_symlink
    backup_link_conflict "$HOME/.gitconfig"
    backup_link_conflict "$HOME/.codex/config.toml"
    backup_link_conflict "$HOME/.codex/AGENTS.md"
    backup_link_conflict "$HOME/.codex/skills/weekly-update"
    backup_link_conflict "$HOME/.claude/settings.json"
    backup_link_conflict "$HOME/.claude/statusline.py"
    backup_link_conflict "$HOME/.claude/hooks/block-git-rewrites.py"
    backup_link_conflict "$HOME/.claude/setup-claude-vertex-auth.sh"
    backup_link_conflict "$HOME/.aider.conf.yml"
    backup_link_conflict "$HOME/.aider.model.metadata.json"
    backup_link_conflict "$HOME/.aider.model.settings.yml"
    backup_link_conflict "$HOME/.aider/CONVENTIONS.md"
    backup_link_conflict "$HOME/.config/ghostty/config.ghostty"
    backup_link_conflict "$HOME/.qwen/settings.json"
    backup_link_conflict "$HOME/.qwen/QWEN.md"
    backup_link_conflict "$HOME/.local/bin/install-qwen-code"
    backup_link_conflict "$HOME/.local/bin/qwen"
    remove_legacy_managed_link "$HOME/.local/bin/qwen-remote"
    remove_legacy_managed_link "$HOME/.local/bin/qwen-weckerAA"
}

ensure_required_submodules

if should_install_macos_packages; then
    if [ -f "${DOTFILES}/scripts/install-macos-packages.sh" ]; then
        bash "${DOTFILES}/scripts/install-macos-packages.sh"
    fi
fi

prepare_dotbot_link_conflicts

DOTBOT_BIN="${BASEDIR}/submodules/dotbot/bin/dotbot"
if [ -f "$DOTBOT_BIN" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$DOTBOT_BIN" -d "$BASEDIR" -c "install.conf.yaml" "${@}"
elif UV_BIN="$(uv_bin)"; then
    "$UV_BIN" tool run dotbot -d "$BASEDIR" -c "install.conf.yaml" "${@}"
else
    printf '%s\n' "dotbot is unavailable." >&2
    printf '%s\n' "Initialize submodules with: git submodule update --init --recursive --remote" >&2
    printf '%s\n' "Or install uv and rerun ./install to bootstrap dotbot without the submodule." >&2
    exit 1
fi

if should_install_linux_packages; then
    if [ -x "${DOTFILES}/scripts/install-slurm-client.sh" ]; then
        if ! "${DOTFILES}/scripts/install-slurm-client.sh"; then
            printf '%s\n' "⚠️  slurm-client installation failed; continuing dotfiles install." >&2
        fi
    fi

    if [ -f "${DOTFILES}/scripts/install-linux-packages.sh" ]; then
        if ! bash "${DOTFILES}/scripts/install-linux-packages.sh"; then
            printf '%s\n' "⚠️  Linux package installation failed; continuing dotfiles install." >&2
        fi
    fi
fi

if [ -f "${DOTFILES}/scripts/install-codex.sh" ]; then
    if ! bash "${DOTFILES}/scripts/install-codex.sh"; then
        printf '%s\n' "⚠️  Codex CLI installation failed; continuing dotfiles install." >&2
    fi
fi

if [ -f "${DOTFILES}/scripts/install-claude.sh" ]; then
    if ! bash "${DOTFILES}/scripts/install-claude.sh"; then
        printf '%s\n' "⚠️  Claude Code installation failed; continuing dotfiles install." >&2
    fi
fi

if [ -f "${DOTFILES}/scripts/install-qwen-code.sh" ]; then
    if ! bash "${DOTFILES}/scripts/install-qwen-code.sh"; then
        printf '%s\n' "⚠️  Qwen Code installation failed; continuing dotfiles install." >&2
    fi
fi

if [ -f "${DOTFILES}/scripts/install-go.sh" ]; then
    if ! bash "${DOTFILES}/scripts/install-go.sh"; then
        printf '%s\n' "Go installation failed; aborting dotfiles install." >&2
        exit 1
    fi
fi

if [ -f "${DOTFILES}/scripts/install-sudoku.sh" ] \
    && { [ -n "${SUDOKU_SOURCE:-}" ] || [ -d "$HOME/git/languages/rust/Sudoku" ]; }; then
    if ! bash "${DOTFILES}/scripts/install-sudoku.sh"; then
        printf '%s\n' "⚠️  Sudoku installation failed; continuing dotfiles install." >&2
    fi
fi

dotbins_bin() {
    if command -v dotbins >/dev/null 2>&1; then
        command -v dotbins
        return 0
    fi

    if [ -x "$HOME/.local/bin/dotbins" ]; then
        printf '%s\n' "$HOME/.local/bin/dotbins"
        return 0
    fi

    return 1
}

dotbins_sync_current() {
    local dotbins_bin
    dotbins_bin="$1"

    if [ "$(uname -s)" = "Darwin" ]; then
        # eza has no upstream macOS release asset; the Brewfile installs it instead.
        "$dotbins_bin" sync --current \
            delta duf dust fd gh git-lfs hyperfine rg tree-sitter yazi zellij \
            bat direnv fzf lazygit micromamba starship zoxide atuin keychain uv
        return
    fi

    "$dotbins_bin" sync --current
}

network_host_resolves() {
    local host
    host="$1"

    if command -v getent >/dev/null 2>&1; then
        getent hosts "$host" >/dev/null 2>&1
        return $?
    fi

    if command -v dscacheutil >/dev/null 2>&1; then
        dscacheutil -q host -a name "$host" >/dev/null 2>&1
        return $?
    fi

    return 0
}

should_sync_network_tools() {
    local host description
    host="$1"
    description="$2"

    case "${DOTFILES_SYNC_TOOLS:-auto}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        0|false|FALSE|no|NO)
            return 1
            ;;
    esac

    if network_host_resolves "$host"; then
        return 0
    fi

    printf '%s\n' "⚠️  Cannot resolve $host; skipping $description." >&2
    printf '%s\n' "    Set DOTFILES_SYNC_TOOLS=1 to force network tool sync." >&2
    return 1
}

ensure_symlink() {
    local source target
    source="$1"
    target="$2"

    if [ -L "$target" ] && [ "$(readlink "$target")" = "$source" ]; then
        return 0
    fi

    ln -sf "$source" "$target"
}

sanitize_github_token_env() {
    case "${GITHUB_TOKEN:-}" in
        ""|*[[:space:]]*) unset GITHUB_TOKEN ;;
    esac

    case "${GH_TOKEN:-}" in
        ""|*[[:space:]]*) unset GH_TOKEN ;;
    esac

    case "${GITHUB_PAT_TOKEN:-}" in
        ""|*[[:space:]]*) unset GITHUB_PAT_TOKEN ;;
    esac

    if [ -z "${GITHUB_TOKEN:-}" ] && [ -n "${GH_TOKEN:-}" ]; then
        export GITHUB_TOKEN="${GH_TOKEN}"
    fi

    if [ -z "${GITHUB_TOKEN:-}" ] && [ -n "${GITHUB_PAT_TOKEN:-}" ]; then
        export GITHUB_TOKEN="${GITHUB_PAT_TOKEN}"
    fi

    if [ -z "${GH_TOKEN:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
        export GH_TOKEN="${GITHUB_TOKEN}"
    fi

    if [ -z "${GITHUB_PAT_TOKEN:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
        export GITHUB_PAT_TOKEN="${GITHUB_TOKEN}"
    fi
}

sanitize_github_token_env

if should_sync_network_tools "pypi.org" "uv tool sync" && ! bash "${DOTFILES}/scripts/sync-uv-tools.sh"; then
    printf '%s\n' "⚠️  uv tool sync failed; continuing dotfiles install." >&2
fi

if DOTBINS_BIN="$(dotbins_bin)"; then
    if should_sync_network_tools "api.github.com" "dotbins sync" && ! dotbins_sync_current "$DOTBINS_BIN"; then
        printf '%s\n' "⚠️  dotbins sync failed; continuing dotfiles install." >&2
    fi
else
    printf '%s\n' "⚠️  dotbins is not installed; skipping CLI tool sync." >&2
    printf '%s\n' "    Install uv and rerun ./install to provision tools like micromamba." >&2
fi

mkdir -p "$HOME/.config/tmuxp"

if [ -f "$DOTFILES/submodules/tmux/.tmux.conf" ]; then
    ensure_symlink "$DOTFILES/submodules/tmux/.tmux.conf" "$HOME/.tmux.conf"
fi

if [ -f "$DOTFILES/submodules/tmux/.tmux.conf.local" ]; then
    ensure_symlink "$DOTFILES/submodules/tmux/.tmux.conf.local" "$HOME/.tmux.conf.local"
fi

# symlink each YAML session file
for f in "$DOTFILES"/tmux/sessions/*.yaml; do
  [ -e "$f" ] || continue
  ensure_symlink "$f" "$HOME/.config/tmuxp/$(basename "$f")"
done
