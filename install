#!/usr/bin/env bash
set -euo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${BASEDIR}"
DOTFILES="${DOTFILES:-$BASEDIR}"

ensure_required_submodules() {
    local missing=()

    if [ ! -f "${BASEDIR}/submodules/dotbot/bin/dotbot" ]; then
        missing+=("submodules/dotbot")
    fi

    if [ ! -f "${BASEDIR}/submodules/kickstart.nvim/init.lua" ]; then
        missing+=("submodules/kickstart.nvim")
    fi

    if [ "${#missing[@]}" -eq 0 ]; then
        return 0
    fi

    if ! command -v git >/dev/null 2>&1; then
        printf '%s\n' "⚠️  git is unavailable; cannot initialize required submodules: ${missing[*]}" >&2
        return 1
    fi

    printf '%s\n' "📦 Initializing required submodules: ${missing[*]}"
    git submodule sync -- "${missing[@]}"
    git submodule update --init --recursive -- "${missing[@]}"
}

should_install_linux_packages() {
    case "${DOTFILES_INSTALL_SYSTEM_PACKAGES:-auto}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        0|false|FALSE|no|NO)
            return 1
            ;;
    esac

    if [ "$(uname -s)" != "Linux" ]; then
        return 1
    fi

    if [ -n "${SLURM_CONF:-}" ] || [ -f /etc/slurm/slurm.conf ] || [ -d /etc/slurm/slurm.conf.d ] \
        || command -v slurmctld >/dev/null 2>&1 || command -v slurmdbd >/dev/null 2>&1; then
        printf '%s\n' "⚠️  Detected a Slurm-managed host; skipping privileged Linux package installation." >&2
        printf '%s\n' "    Set DOTFILES_INSTALL_SYSTEM_PACKAGES=1 to force these apt-based install steps." >&2
        return 1
    fi

    return 0
}

should_install_macos_packages() {
    case "${DOTFILES_INSTALL_SYSTEM_PACKAGES:-auto}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        0|false|FALSE|no|NO)
            return 1
            ;;
    esac

    [ "$(uname -s)" = "Darwin" ]
}

uv_bin() {
    if command -v uv >/dev/null 2>&1; then
        command -v uv
        return 0
    fi

    local os arch candidate
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    if [ "$os" = "darwin" ]; then
        os="macos"
    fi

    arch=$(uname -m)
    if [ "$arch" = "x86_64" ]; then
        arch="amd64"
    elif [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
        arch="arm64"
    fi

    candidate="$HOME/.dotbins/$os/$arch/bin/uv"
    if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    return 1
}

DOTFILES_BACKUP_ROOT=""

dotfiles_backup_root() {
    if [ -n "${DOTFILES_BACKUP_DIR:-}" ]; then
        printf '%s\n' "$DOTFILES_BACKUP_DIR"
        return 0
    fi

    if [ -z "$DOTFILES_BACKUP_ROOT" ]; then
        DOTFILES_BACKUP_ROOT="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"
    fi

    printf '%s\n' "$DOTFILES_BACKUP_ROOT"
}

backup_link_conflict() {
    local target backup_root rel dest suffix
    target="$1"

    if [ -L "$target" ] || [ ! -e "$target" ]; then
        return 0
    fi

    backup_root="$(dotfiles_backup_root)"
    rel="${target#"$HOME"/}"
    if [ "$rel" = "$target" ]; then
        rel="${target#/}"
    fi
    dest="$backup_root/$rel"
    mkdir -p "$(dirname "$dest")"

    suffix=1
    while [ -e "$dest" ] || [ -L "$dest" ]; do
        dest="$backup_root/$rel.$suffix"
        suffix=$((suffix + 1))
    done

    printf '%s\n' "Backing up existing $target -> $dest"
    mv "$target" "$dest"
}

prepare_dotbot_link_conflicts() {
    backup_link_conflict "$HOME/.gitconfig"
    backup_link_conflict "$HOME/.codex/config.toml"
    backup_link_conflict "$HOME/.codex/AGENTS.md"
    backup_link_conflict "$HOME/.codex/skills/weekly-update"
    backup_link_conflict "$HOME/.config/ghostty/config.ghostty"
}

ensure_required_submodules

if should_install_macos_packages; then
    if [ -f "${DOTFILES}/scripts/install-macos-packages.sh" ]; then
        bash "${DOTFILES}/scripts/install-macos-packages.sh"
    fi
fi

prepare_dotbot_link_conflicts

DOTBOT_BIN="${BASEDIR}/submodules/dotbot/bin/dotbot"
if [ -f "$DOTBOT_BIN" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$DOTBOT_BIN" -d "$BASEDIR" -c "install.conf.yaml" "${@}"
elif UV_BIN="$(uv_bin)"; then
    "$UV_BIN" tool run dotbot -d "$BASEDIR" -c "install.conf.yaml" "${@}"
else
    printf '%s\n' "dotbot is unavailable." >&2
    printf '%s\n' "Initialize submodules with: git submodule update --init --recursive --remote" >&2
    printf '%s\n' "Or install uv and rerun ./install to bootstrap dotbot without the submodule." >&2
    exit 1
fi

if should_install_linux_packages; then
    if [ -x "${DOTFILES}/scripts/install-slurm-client.sh" ]; then
        if ! "${DOTFILES}/scripts/install-slurm-client.sh"; then
            printf '%s\n' "⚠️  slurm-client installation failed; continuing dotfiles install." >&2
        fi
    fi

    if [ -f "${DOTFILES}/scripts/install-linux-packages.sh" ]; then
        if ! bash "${DOTFILES}/scripts/install-linux-packages.sh"; then
            printf '%s\n' "⚠️  Linux package installation failed; continuing dotfiles install." >&2
        fi
    fi
fi

if [ -f "${DOTFILES}/scripts/install-codex.sh" ]; then
    bash "${DOTFILES}/scripts/install-codex.sh"
fi

if [ -f "${DOTFILES}/scripts/install-sudoku.sh" ]; then
    if ! bash "${DOTFILES}/scripts/install-sudoku.sh"; then
        printf '%s\n' "⚠️  Sudoku installation failed; continuing dotfiles install." >&2
    fi
fi

dotbins_bin() {
    if command -v dotbins >/dev/null 2>&1; then
        command -v dotbins
        return 0
    fi

    if [ -x "$HOME/.local/bin/dotbins" ]; then
        printf '%s\n' "$HOME/.local/bin/dotbins"
        return 0
    fi

    return 1
}

dotbins_sync_current() {
    local dotbins_bin
    dotbins_bin="$1"

    if [ "$(uname -s)" = "Darwin" ]; then
        # eza has no upstream macOS release asset; the Brewfile installs it instead.
        "$dotbins_bin" sync --current \
            delta duf dust fd gh git-lfs hyperfine rg tree-sitter yazi zellij \
            bat direnv fzf lazygit micromamba starship zoxide atuin keychain uv
        return
    fi

    "$dotbins_bin" sync --current
}

sanitize_github_token_env() {
    case "${GITHUB_TOKEN:-}" in
        ""|*[[:space:]]*) unset GITHUB_TOKEN ;;
    esac

    case "${GH_TOKEN:-}" in
        ""|*[[:space:]]*) unset GH_TOKEN ;;
    esac

    case "${GITHUB_PAT_TOKEN:-}" in
        ""|*[[:space:]]*) unset GITHUB_PAT_TOKEN ;;
    esac

    if [ -z "${GITHUB_TOKEN:-}" ] && [ -n "${GH_TOKEN:-}" ]; then
        export GITHUB_TOKEN="${GH_TOKEN}"
    fi

    if [ -z "${GITHUB_TOKEN:-}" ] && [ -n "${GITHUB_PAT_TOKEN:-}" ]; then
        export GITHUB_TOKEN="${GITHUB_PAT_TOKEN}"
    fi

    if [ -z "${GH_TOKEN:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
        export GH_TOKEN="${GITHUB_TOKEN}"
    fi

    if [ -z "${GITHUB_PAT_TOKEN:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
        export GITHUB_PAT_TOKEN="${GITHUB_TOKEN}"
    fi
}

sanitize_github_token_env

bash "${DOTFILES}/scripts/sync-uv-tools.sh"

if DOTBINS_BIN="$(dotbins_bin)"; then
    dotbins_sync_current "$DOTBINS_BIN"
else
    printf '%s\n' "⚠️  dotbins is not installed; skipping CLI tool sync." >&2
    printf '%s\n' "    Install uv and rerun ./install to provision tools like micromamba." >&2
fi

mkdir -p "$HOME/.config/tmuxp"

if [ -f "$DOTFILES/submodules/tmux/.tmux.conf" ]; then
    ln -sf "$DOTFILES/submodules/tmux/.tmux.conf" "$HOME/.tmux.conf"
fi

if [ -f "$DOTFILES/submodules/tmux/.tmux.conf.local" ]; then
    ln -sf "$DOTFILES/submodules/tmux/.tmux.conf.local" "$HOME/.tmux.conf.local"
fi

# symlink each YAML session file
for f in "$DOTFILES"/tmux/sessions/*.yaml; do
  ln -sf "$f" "$HOME/.config/tmuxp/$(basename "$f")"
done
